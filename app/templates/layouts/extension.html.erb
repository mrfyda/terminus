<!DOCTYPE html>

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">

    <title><%= content_for :title %></title>

    <meta charset="utf-8">
    <meta name="description" content="A TRMNL server.">
    <meta name="author" content="TRMNL">

    <%= tag.link title: "TRMNL: Stylesheet",
                 rel: :stylesheet,
                 href: "https://trmnl.com/css/latest/plugins.css" %>

    <style type="text/css">
      :where(body) {
        align-items: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .screen {
        <%= content_for :screen_variables %>
      }
    </style>

    <%= javascript_tag "https://trmnl.com/js/latest/plugins.js" %>
  </head>

  <body class="trmnl">
    <%= yield %>
  </body>
</html>

